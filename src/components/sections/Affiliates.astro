---
const affiliates = [
  {
    name: "Asiaven Constructora",
    image: "https://images.unsplash.com/photo-1541888086425-d81bb19240f5?auto=format&fit=crop&q=80&w=800",
  },
  {
    name: "Asiaven Elevators",
    image: "https://images.unsplash.com/photo-1567157577867-05ccb1388e13?auto=format&fit=crop&q=80&w=800",
  },
  {
    name: "Asiaven Motors",
    image: "https://images.unsplash.com/photo-1558618666-fcd25c85f82e?auto=format&fit=crop&q=80&w=800",
  },
];
---

<section class="bg-gray-50 px-6 py-20 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-3xl text-center">
      <span class="text-sm font-semibold uppercase tracking-widest text-corporativo-blue">
        Empresas Asiaven
      </span>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-corporativo-gray md:text-4xl lg:text-5xl">
        Más que un lujo es una necesidad
      </h2>
      <p class="mt-5 text-base leading-relaxed text-gray-500 md:text-lg">
        Asiaven está compuesto por diversas filiales que abarcan desde la construcción de infraestructuras hasta la implementación de sistemas de ascensores y motores. Esta estructura nos permite ofrecer un servicio integral que incluye diseño, ejecución y un compromiso con la calidad.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-3">
      {affiliates.map(({ name, image }) => (
        <a href="#" class="group overflow-hidden rounded-xl bg-white shadow-md transition-shadow duration-300 hover:shadow-xl">
          <div class="overflow-hidden">
            <img
              src={image}
              alt={name}
              class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold text-corporativo-gray transition-colors duration-200 group-hover:text-corporativo-blue">
              {name}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
