---
import { MapPin, Mail, Phone } from "lucide-react";

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/#nosotros" },
  { label: "Proyectos", href: "/proyectos" },
  { label: "Servicios", href: "/servicios" },
  { label: "Contáctanos", href: "/contactanos" },
];

const contactInfo = [
  { Icon: MapPin, text: "C.C Paseo Las Mercedes, Piso 2, Caracas, Venezuela" },
  { Icon: Mail, text: "proyectos@asiaven.com" },
  { Icon: Phone, text: "+58 212-9924333" },
];
---

<footer class="bg-corporativo-gray text-gray-300">
  <div class="mx-auto max-w-7xl px-6 py-14 lg:px-8">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
      <div>
        <a href="/" class="text-2xl font-bold tracking-widest text-white">ASIAVEN</a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-gray-400">
          Servicios de construcción, maquinaria pesada e importación y distribución de productos desde el continente asiático.
        </p>
        <p class="mt-4 max-w-xs text-sm italic leading-relaxed text-gray-500">
          "El camino hacia el éxito siempre está en construcción".
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-widest text-white">
          Enlaces Rápidos
        </h4>
        <ul class="mt-4 flex flex-col gap-3">
          {quickLinks.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class="text-sm text-gray-400 transition-colors duration-200 hover:text-white"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-widest text-white">
          Contacto
        </h4>
        <ul class="mt-4 flex flex-col gap-3">
          {contactInfo.map(({ Icon, text }) => (
            <li class="flex items-center gap-3 text-sm text-gray-400">
              <Icon className="h-5 w-5 text-corporativo-blue" />
              <span>{text}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/15 pt-8 text-center">
      <p class="text-xs text-gray-500">
        &copy; {currentYear} Asiaven. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
