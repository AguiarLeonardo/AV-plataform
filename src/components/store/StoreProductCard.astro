---
interface Props {
  title: string;
  image: string;
  specs: string[];
  badge?: string;
  href?: string;
  dataPrice?: number;
  productId?: number;
}

const { title, image, specs, badge, href = "#", dataPrice = 0, productId = 0 } = Astro.props;

const visibleCount = 2;
const visibleSpecs = specs.slice(0, visibleCount);
const extraSpecs = specs.slice(visibleCount);
---

<div
  class="store-product-card relative flex flex-col rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md"
  data-name={title}
  data-price={dataPrice}
>
  {badge && (
    <span class="absolute left-3 top-3 z-10 rounded-md bg-corporativo-blue px-2 py-1 text-xs font-semibold text-white">
      {badge}
    </span>
  )}

  <div class="flex h-40 items-center justify-center">
    <img src={image} alt={title} class="max-h-full max-w-full object-contain" loading="lazy" decoding="async" />
  </div>

  <div class="mt-4">
    <h3 class="text-sm font-medium text-gray-700">{title}</h3>
  </div>

  <ul class="mt-3 flex flex-col gap-1 text-xs text-gray-500">
    {visibleSpecs.map((spec) => (
      <li class="flex items-start gap-1.5">
        <span class="mt-1 h-1 w-1 flex-shrink-0 rounded-full bg-gray-400" />
        <span>{spec}</span>
      </li>
    ))}
    {extraSpecs.map((spec) => (
      <li class="spec-extra flex items-start gap-1.5" style="display: none;">
        <span class="mt-1 h-1 w-1 flex-shrink-0 rounded-full bg-gray-400" />
        <span>{spec}</span>
      </li>
    ))}
  </ul>

  {extraSpecs.length > 0 && (
    <button
      type="button"
      data-specs-toggle="more"
      class="specs-toggle-more mt-1 self-start text-xs font-semibold text-corporativo-blue hover:underline"
    >
      Ver más
    </button>
  )}
  {extraSpecs.length > 0 && (
    <button
      type="button"
      data-specs-toggle="less"
      class="specs-toggle-less mt-1 self-start text-xs font-semibold text-corporativo-blue hover:underline"
      style="display: none;"
    >
      Ver menos
    </button>
  )}

  <div class="mt-4 flex flex-col gap-2">
    <button
      type="button"
      data-add-to-quote
      data-product-id={productId}
      data-product-name={title}
      data-product-price={dataPrice}
      class="w-full rounded-md bg-corporativo-blue py-2 text-center text-sm font-semibold text-white transition-colors hover:bg-corporativo-blue/90"
    >
      Agregar a Cotización
    </button>
    <a
      href={href}
      class="w-full rounded-md border border-corporativo-blue py-2 text-center text-sm font-semibold text-corporativo-blue no-underline transition-colors hover:bg-blue-50"
    >
      Saber más
    </a>
  </div>
</div>

<script>
  import { addToCart } from "../../store/quoteCart";

  document.querySelectorAll<HTMLButtonElement>("[data-specs-toggle]").forEach((button) => {
    button.addEventListener("click", () => {
      const card = button.closest<HTMLElement>(".store-product-card");
      if (!card) return;

      const expand = button.dataset.specsToggle === "more";

      card.querySelectorAll<HTMLElement>(".spec-extra").forEach((li) => {
        li.style.display = expand ? "flex" : "none";
      });
      const moreBtn = card.querySelector<HTMLElement>(".specs-toggle-more");
      const lessBtn = card.querySelector<HTMLElement>(".specs-toggle-less");
      if (moreBtn) moreBtn.style.display = expand ? "none" : "";
      if (lessBtn) lessBtn.style.display = expand ? "" : "none";
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-add-to-quote]").forEach((button) => {
    const originalLabel = button.textContent ?? "Agregar a Cotización";
    let feedbackTimer: ReturnType<typeof setTimeout> | undefined;

    button.addEventListener("click", () => {
      addToCart({
        id: Number(button.dataset.productId),
        name: button.dataset.productName ?? "",
        fakePrice: Number(button.dataset.productPrice),
      });

      button.textContent = "¡Agregado!";
      button.disabled = true;
      clearTimeout(feedbackTimer);
      feedbackTimer = setTimeout(() => {
        button.textContent = originalLabel;
        button.disabled = false;
      }, 2000);
    });
  });
</script>
