---
interface Props {
  title: string;
  price: string;
  image: string;
  specs: string[];
  badge?: string;
  details?: string;
  href?: string;
}

const { title, price, image, specs, badge, details, href = "#" } = Astro.props;
---

<div class="relative flex flex-col rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-shadow hover:shadow-md">
  {badge && (
    <span class="absolute left-3 top-3 z-10 rounded-md bg-corporativo-blue px-2 py-1 text-xs font-semibold text-white">
      {badge}
    </span>
  )}

  <div class="flex h-40 items-center justify-center">
    <img src={image} alt={title} class="max-h-full max-w-full object-contain" loading="lazy" decoding="async" />
  </div>

  <div class="mt-4">
    <h3 class="text-sm font-medium text-gray-700">{title}</h3>
    <p class="mt-1 text-2xl font-bold text-gray-900">{price}</p>
  </div>

  <ul class="mt-3 flex flex-col gap-1 text-xs text-gray-500">
    {specs.slice(0, 4).map((spec) => (
      <li class="flex items-start gap-1.5">
        <span class="mt-1 h-1 w-1 flex-shrink-0 rounded-full bg-gray-400" />
        <span>{spec}</span>
      </li>
    ))}
  </ul>

  {details && (
    <details class="mt-2">
      <summary class="cursor-pointer list-none text-xs font-semibold text-corporativo-blue [&::-webkit-details-marker]:hidden">
        Ver más
      </summary>
      <p class="mt-2 text-xs leading-relaxed text-gray-500">{details}</p>
    </details>
  )}

  <div class="mt-4 flex flex-col gap-2">
    <a
      href="#"
      class="w-full rounded-md bg-corporativo-blue py-2 text-center text-sm font-semibold text-white no-underline transition-colors hover:bg-corporativo-blue/90"
    >
      Comprar
    </a>
    <a
      href={href}
      class="w-full rounded-md border border-corporativo-blue py-2 text-center text-sm font-semibold text-corporativo-blue no-underline transition-colors hover:bg-blue-50"
    >
      Saber más
    </a>
  </div>
</div>
