---
interface Props {
  title: string;
  image: string;
  price: string;
  badge?: "Nuevo" | "Oferta" | "Más Vendido";
  href: string;
}

const { title, image, price, badge, href } = Astro.props;

const badgeStyles: Record<string, string> = {
  Nuevo: "bg-corporativo-blue text-white",
  Oferta: "bg-red-600 text-white",
  "Más Vendido": "bg-amber-500 text-white",
};
---

<a
  href={href}
  class="group relative flex flex-col rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg no-underline"
>
  {badge && (
    <span class={`absolute left-3 top-3 z-10 rounded-md px-2 py-1 text-xs font-semibold ${badgeStyles[badge]}`}>
      {badge}
    </span>
  )}

  <div class="flex h-36 items-center justify-center sm:h-40">
    <img
      src={image}
      alt={title}
      class="max-h-full max-w-full object-contain transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
      decoding="async"
    />
  </div>

  <h3 class="mt-4 line-clamp-2 text-sm font-medium text-gray-700">{title}</h3>
  <p class="mt-1 text-lg font-bold text-gray-900">{price}</p>
</a>
