---
interface Props {
  href: string;
  image: string;
  title: string;
}

const { href, image, title } = Astro.props;
---

<a
  href={href}
  class="group overflow-hidden rounded-xl border border-gray-200 bg-white transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
>
  <img
    src={image}
    alt={title}
    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
    decoding="async"
  />
  <div class="p-5">
    <h3 class="text-lg font-bold text-corporativo-gray transition-colors duration-200 group-hover:text-corporativo-blue">
      {title}
    </h3>
  </div>
</a>
