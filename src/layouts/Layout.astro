---
import "../styles/global.css";
import WhatsAppButton from "../components/sections/WhatsAppButton.astro";

interface Props {
  title?: string;
}

const { title = "Asiaven - B2B" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Asiaven — Servicios de construcción, maquinaria pesada e importación desde Asia." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-corporativo-gray antialiased">
    <slot />
    <WhatsAppButton />
  </body>
</html>
