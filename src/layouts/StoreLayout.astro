---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Asiaven Store" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Asiaven Store — Equipos de cómputo, servidores y soluciones tecnológicas para empresas." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 antialiased">
    <slot />
  </body>
</html>
