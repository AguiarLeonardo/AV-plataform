---
import Layout from "../../layouts/Layout.astro";
import { packagingCategories } from "../../data/packagingCatalog";
import { ArrowLeft, ChevronLeft, ChevronRight } from "lucide-react";

export function getStaticPaths() {
  return packagingCategories.map((category) => ({
    params: { categoria: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
---

<Layout title={`${category.title} - Catálogo de Envases - Asiaven`}>
  <div class="max-w-7xl mx-auto px-4 pt-24 pb-10">
    <a
      href="/envases"
      class="inline-flex items-center gap-2 text-sm font-semibold text-corporativo-blue hover:underline"
    >
      <ArrowLeft className="h-4 w-4" />
      Volver al Catálogo
    </a>

    <h1 class="mt-6 mb-4 text-4xl font-bold text-gray-900">{category.title}</h1>
    <p class="max-w-3xl text-lg text-gray-600">{category.description}</p>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-16 md:pb-24">
    {
      category.subcategories.map((subcategory) => (
        <section class="mb-14 last:mb-0">
          <h2 class="text-2xl font-bold text-corporativo-gray mb-1">{subcategory.title}</h2>
          {subcategory.description && (
            <p class="text-sm text-gray-500 max-w-2xl mb-5">{subcategory.description}</p>
          )}

          <div class="group/row relative">
            <div
              class="flex overflow-x-auto gap-6 pb-6 snap-x snap-mandatory scroll-smooth [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
              data-carousel={subcategory.slug}
            >
              {subcategory.products.map((product) => (
                <a
                  href={`/envases/producto/${product.slug}`}
                  class="group w-72 min-w-[280px] flex-shrink-0 snap-start overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
                >
                  <img
                    src={category.image}
                    alt={product.title}
                    class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="p-4">
                    <h3 class="font-bold text-corporativo-gray transition-colors duration-200 group-hover:text-corporativo-blue">
                      {product.title}
                    </h3>
                    {product.group && <p class="mt-1 text-xs text-gray-500">{product.group}</p>}
                  </div>
                </a>
              ))}
            </div>

            <button
              type="button"
              class="carousel-nav-btn absolute left-0 top-1/2 z-10 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 text-corporativo-gray opacity-0 shadow-lg transition-opacity duration-300 hover:bg-white group-hover/row:opacity-100"
              data-carousel-target={subcategory.slug}
              data-direction="left"
              aria-label={`Desplazar ${subcategory.title} hacia la izquierda`}
            >
              <ChevronLeft className="h-5 w-5" />
            </button>
            <button
              type="button"
              class="carousel-nav-btn absolute right-0 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 translate-x-1/2 items-center justify-center rounded-full bg-white/90 text-corporativo-gray opacity-0 shadow-lg transition-opacity duration-300 hover:bg-white group-hover/row:opacity-100"
              data-carousel-target={subcategory.slug}
              data-direction="right"
              aria-label={`Desplazar ${subcategory.title} hacia la derecha`}
            >
              <ChevronRight className="h-5 w-5" />
            </button>
          </div>
        </section>
      ))
    }
  </div>
</Layout>

<script>
  const navButtons = document.querySelectorAll<HTMLButtonElement>(".carousel-nav-btn");

  navButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetSlug = button.dataset.carouselTarget;
      const direction = button.dataset.direction;
      const carousel = document.querySelector<HTMLElement>(`[data-carousel="${targetSlug}"]`);
      if (!carousel) return;

      const firstCard = carousel.querySelector<HTMLElement>(":scope > a");
      const cardWidth = firstCard ? firstCard.offsetWidth + 24 : 300;

      carousel.scrollBy({
        left: direction === "left" ? -cardWidth : cardWidth,
        behavior: "smooth",
      });
    });
  });
</script>
