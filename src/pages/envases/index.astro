---
import Layout from "../../layouts/Layout.astro";
import { packagingCategories } from "../../data/packagingCatalog";
---

<Layout title="Catálogo de Envases Metálicos - Asiaven">
  <div class="max-w-7xl mx-auto px-4 pt-24 pb-10">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Catálogo de Envases Metálicos</h1>
    <p class="text-lg text-gray-600 max-w-3xl">
      Todos los productos usan materiales que cumplen estándares de seguridad alimentaria, tienen
      buena hermeticidad y bloqueo de luz, y tras el llenado/esterilización cumplen requisitos de
      esterilidad comercial (vida útil entre 18 meses y 3 años según la línea).
    </p>
  </div>

  <div class="flex w-full h-[70vh] md:h-[80vh] overflow-hidden">
    {
      packagingCategories.map((category) => (
        <a
          href={`/envases/${category.slug}`}
          class="group relative flex-1 overflow-hidden transition-all duration-500 ease-in-out hover:flex-[3_3_0%] cursor-pointer"
        >
          <img
            src={category.image}
            alt={category.title}
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-black/40 transition-colors duration-500 group-hover:bg-black/60" />

          <div class="absolute inset-0 flex items-center justify-center pb-4 opacity-100 transition-opacity duration-300 group-hover:opacity-0">
            <span class="-rotate-90 whitespace-nowrap text-lg font-bold uppercase tracking-wide text-white md:text-xl">
              {category.title}
            </span>
          </div>

          <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 transition-opacity delay-200 duration-500 group-hover:opacity-100 md:p-8">
            <h2 class="mb-2 text-2xl font-bold text-white md:text-3xl">{category.title}</h2>
            <p class="mb-4 max-w-md text-sm text-gray-200">{category.shortDescription}</p>
            <ul class="mb-6 space-y-1">
              {category.subcategories.map((subcategory) => (
                <li class="text-xs text-gray-300 md:text-sm">&bull; {subcategory.title}</li>
              ))}
            </ul>
            <span class="inline-flex w-fit items-center gap-2 rounded-lg bg-white px-5 py-2.5 text-sm font-semibold text-corporativo-gray shadow-lg transition-colors group-hover:bg-gray-100">
              Ver Catálogo &rarr;
            </span>
          </div>
        </a>
      ))
    }
  </div>
</Layout>
