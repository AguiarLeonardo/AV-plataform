---
import Layout from "../../layouts/Layout.astro";
import { packagingCategories } from "../../data/packagingCatalog";
---

<Layout title="Catálogo de Envases Metálicos - Asiaven">
  <div class="max-w-7xl mx-auto px-4 pt-24 pb-10">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Catálogo de Envases Metálicos</h1>
    <p class="text-lg text-gray-600 max-w-3xl">
      Todos los productos usan materiales que cumplen estándares de seguridad alimentaria, tienen
      buena hermeticidad y bloqueo de luz, y tras el llenado/esterilización cumplen requisitos de
      esterilidad comercial (vida útil entre 18 meses y 3 años según la línea).
    </p>
  </div>

  <div class="max-w-7xl mx-auto px-4 pb-16 md:pb-24">
    {
      packagingCategories.map((category) => (
        <section class="mb-14 last:mb-0">
          <h2 class="text-2xl font-bold text-corporativo-gray mb-1">{category.title}</h2>
          {category.shortDescription && (
            <p class="text-sm text-gray-500 max-w-2xl mb-5">{category.shortDescription}</p>
          )}

          <div class="flex overflow-x-auto gap-6 pb-6 snap-x snap-mandatory scroll-smooth [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
            {category.products.map((product) => (
              <a
                href={`/envases/producto/${product.slug}`}
                class="group w-72 min-w-[280px] flex-shrink-0 snap-start overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              >
                <img
                  src={category.image}
                  alt={product.title}
                  class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
                <div class="p-4">
                  <h3 class="font-bold text-corporativo-gray transition-colors duration-200 group-hover:text-corporativo-blue">
                    {product.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>
