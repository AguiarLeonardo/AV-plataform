---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/sections/Navbar.astro";
import Footer from "../../components/sections/Footer.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import ServiceSlider from "../../components/react/ServiceSlider.tsx";
import { services } from "../../data/services";
import { Download } from "lucide-react";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { servicio: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={`${service.title} - Asiaven`}>
  <Navbar />
  <PageHeader title={service.title} bgImage={service.images[0]} />
  <main class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <ServiceSlider images={service.images} client:load />

      <div class="prose prose-lg text-gray-700">
        <h2 class="text-corporativo-gray">{service.title}</h2>
        {service.fullDescription.map((paragraph) => (
          <p class="mb-6 leading-relaxed">{paragraph}</p>
        ))}
        {service.slug === "tecnologia" ? (
          <>
            <a
              href="#"
              class="inline-flex items-center gap-2 rounded-lg bg-corporativo-blue px-6 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90 no-underline"
            >
              <Download className="h-4 w-4" />
              Descargar Catálogo
            </a>

            <div class="mt-8 rounded-xl border border-gray-200 bg-gray-50 p-6">
              <p class="mb-3 font-semibold text-corporativo-gray">
                ¿Posees uno de nuestros equipos?
              </p>
              <a
                href="/soporte-tecnico"
                class="inline-flex items-center gap-2 rounded-lg border-2 border-corporativo-blue px-5 py-2.5 text-sm font-semibold text-corporativo-blue transition-colors hover:bg-corporativo-blue hover:text-white no-underline"
              >
                Ir a Soporte Técnico &rarr;
              </a>
            </div>
          </>
        ) : (
          <a
            href="/contactanos"
            class="inline-flex items-center gap-2 rounded-lg bg-corporativo-blue px-6 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90 no-underline"
          >
            Solicitar Cotización &rarr;
          </a>
        )}
      </div>
    </div>
  </main>
  <Footer />
</Layout>
