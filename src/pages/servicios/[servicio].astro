---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/sections/Navbar.astro";
import Footer from "../../components/sections/Footer.astro";

export function getStaticPaths() {
  return [
    { params: { servicio: "ascensores" } },
    { params: { servicio: "escaleras-mecanicas" } },
    { params: { servicio: "compras-internacionales" } },
    { params: { servicio: "mantenimiento" } },
    { params: { servicio: "tecnologia" } },
    { params: { servicio: "construccion" } },
    { params: { servicio: "envasados" } },
    { params: { servicio: "recipientes-gas-licuado" } },
  ];
}

const { servicio } = Astro.params;
---

<Layout title={`Servicio: ${servicio} - Asiaven`}>
  <Navbar />
  <main class="min-h-[60dvh] flex flex-col items-center justify-center pt-24">
    <h1 class="text-4xl font-bold text-corporativo-gray capitalize">
      Servicio: {servicio?.replace("-", " ")}
    </h1>
    <p class="mt-4 text-lg text-gray-500">Página en construcción</p>
  </main>
  <Footer />
</Layout>
