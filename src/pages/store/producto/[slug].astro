---
import StoreLayout from "../../../layouts/StoreLayout.astro";
import StoreNavigation from "../../../components/react/StoreNavigation.tsx";
import { techProducts } from "../../../data/techCatalog";
import { hrefForRealSubcategory } from "../../../data/storeTaxonomy";
import { ArrowLeft, Check } from "lucide-react";

export function getStaticPaths() {
  return techProducts.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const backHref = hrefForRealSubcategory(product.subcategorySlug);
---

<StoreLayout title={`${product.title} - Asiaven Store`}>
  <StoreNavigation client:load currentPath={backHref} />

  <main class="max-w-6xl mx-auto px-6 py-12">
    <a
      href={backHref}
      class="mb-8 inline-flex items-center gap-2 text-sm font-semibold text-corporativo-blue hover:underline"
    >
      <ArrowLeft className="h-4 w-4" />
      Volver a {product.subcategoryName}
    </a>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
      <div class="flex items-center justify-center rounded-xl border border-gray-100 bg-gray-50 p-10">
        <img
          src={product.image}
          alt={product.title}
          class="max-h-96 w-full object-contain"
          loading="eager"
          decoding="async"
        />
      </div>

      <div>
        <span class="inline-block rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-corporativo-blue">
          {product.subcategoryName}
        </span>

        <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">
          {product.title}
        </h1>

        <p class="mt-2 text-3xl font-bold text-gray-900">Consultar</p>

        <p class="mt-4 text-base leading-relaxed text-gray-600">
          {product.description}
        </p>

        <ul class="mt-6 flex flex-col gap-2">
          {product.features.map((feature) => (
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <Check className="mt-0.5 h-4 w-4 flex-shrink-0 text-corporativo-blue" />
              <span>{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href="/contactanos"
          class="mt-8 inline-flex w-fit items-center gap-2 rounded-lg bg-corporativo-blue px-8 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90 no-underline"
        >
          Solicitar Cotización &rarr;
        </a>
      </div>
    </div>
  </main>
</StoreLayout>
