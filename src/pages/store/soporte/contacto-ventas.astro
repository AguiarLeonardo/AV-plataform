---
import StoreLayout from "../../../layouts/StoreLayout.astro";
import StoreNavigation from "../../../components/react/StoreNavigation.tsx";
---

<StoreLayout title="Contactar a Ventas - Asiaven Store">
  <StoreNavigation client:load currentPath={Astro.url.pathname} />

  <main class="max-w-3xl mx-auto py-16 px-4">
    <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Contactar a Ventas</h1>
    <p class="mt-3 text-base text-gray-600">
      Déjanos tus datos y un especialista en infraestructura tecnológica se comunicará contigo a la brevedad.
    </p>

    <form id="sales-contact-form" class="mt-10 flex flex-col gap-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">Tus Datos</h3>
        <button type="button" class="toggle-b2b text-sm text-gray-500 hover:text-blue-600 underline">
          ¿Compras para una empresa?
        </button>
      </div>

      <div>
        <label for="sales-name" class="mb-1 block text-sm font-medium text-gray-700">Nombre Completo</label>
        <input
          id="sales-name"
          name="name"
          type="text"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div class="business-fields hidden">
        <label for="sales-company" class="mb-1 block text-sm font-medium text-gray-700">Nombre de la Empresa</label>
        <input
          id="sales-company"
          name="company"
          type="text"
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div>
        <label for="sales-email" class="mb-1 block text-sm font-medium text-gray-700">Correo Corporativo</label>
        <input
          id="sales-email"
          name="email"
          type="email"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div>
        <label for="sales-phone" class="mb-1 block text-sm font-medium text-gray-700">Teléfono</label>
        <input
          id="sales-phone"
          name="phone"
          type="tel"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div>
        <label for="sales-interest" class="mb-1 block text-sm font-medium text-gray-700">Solución de Interés</label>
        <select
          id="sales-interest"
          name="interest"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        >
          <option value="">Selecciona una opción</option>
          <option value="equipos-de-computo">Equipos de Cómputo</option>
          <option value="servidores-y-almacenamiento">Servidores y Almacenamiento</option>
          <option value="licenciamiento">Licenciamiento</option>
          <option value="proyecto-a-medida">Proyecto a Medida</option>
        </select>
      </div>

      <div>
        <label for="sales-message" class="mb-1 block text-sm font-medium text-gray-700">
          Mensaje o requerimiento específico
        </label>
        <textarea
          id="sales-message"
          name="message"
          rows={5}
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        ></textarea>
      </div>

      <button
        type="button"
        id="sales-contact-submit"
        class="mt-2 w-full rounded-lg bg-corporativo-blue px-6 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90"
      >
        Enviar Solicitud
      </button>
    </form>
  </main>
</StoreLayout>

<script>
  const submitButton = document.getElementById("sales-contact-submit");
  const form = document.getElementById("sales-contact-form") as HTMLFormElement | null;

  submitButton?.addEventListener("click", () => {
    if (!form?.checkValidity()) {
      form?.reportValidity();
      return;
    }
    alert("Mensaje enviado al equipo de ventas. Nos contactaremos pronto.");
  });

  const toggleButton = document.querySelector<HTMLButtonElement>(".toggle-b2b");
  const businessFields = document.querySelector<HTMLElement>(".business-fields");

  toggleButton?.addEventListener("click", () => {
    businessFields?.classList.toggle("hidden");
    const isHidden = businessFields?.classList.contains("hidden");
    toggleButton.textContent = isHidden ? "¿Compras para una empresa?" : "¿Compra personal?";
  });
</script>
