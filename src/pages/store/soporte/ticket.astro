---
import StoreLayout from "../../../layouts/StoreLayout.astro";
import StoreNavigation from "../../../components/react/StoreNavigation.tsx";
---

<StoreLayout title="Abrir Ticket de Soporte - Asiaven Store">
  <StoreNavigation client:load currentPath={Astro.url.pathname} />

  <main class="max-w-3xl mx-auto py-16 px-4">
    <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">Abrir Ticket de Soporte Técnico</h1>
    <p class="mt-3 text-base text-gray-600">
      Ingresa los datos de tu equipo corporativo para asignarle un técnico especializado.
    </p>

    <form id="ticket-form" class="mt-10 flex flex-col gap-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-bold">Tus Datos</h3>
        <button type="button" class="toggle-b2b text-sm text-gray-500 hover:text-blue-600 underline">
          ¿Soporte para tu empresa?
        </button>
      </div>

      <div>
        <label for="ticket-name" class="mb-1 block text-sm font-medium text-gray-700">Nombre y Apellido</label>
        <input
          id="ticket-name"
          name="name"
          type="text"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div class="business-fields hidden">
        <label for="ticket-company" class="mb-1 block text-sm font-medium text-gray-700">Empresa</label>
        <input
          id="ticket-company"
          name="company"
          type="text"
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div>
        <label for="ticket-serial" class="mb-1 block text-sm font-medium text-gray-700">
          Número de Serie del Equipo (Serial / Service Tag)
        </label>
        <input
          id="ticket-serial"
          name="serial"
          type="text"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        />
      </div>

      <div>
        <label for="ticket-failure-type" class="mb-1 block text-sm font-medium text-gray-700">Tipo de Falla</label>
        <select
          id="ticket-failure-type"
          name="failureType"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        >
          <option value="">Selecciona una opción</option>
          <option value="hardware">Hardware</option>
          <option value="software">Software</option>
          <option value="redes">Redes</option>
          <option value="otro">Otro</option>
        </select>
      </div>

      <div>
        <label for="ticket-description" class="mb-1 block text-sm font-medium text-gray-700">
          Descripción detallada
        </label>
        <textarea
          id="ticket-description"
          name="description"
          rows={5}
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2 text-sm text-gray-700 focus:border-corporativo-blue focus:outline-none"
        ></textarea>
      </div>

      <button
        type="button"
        id="ticket-submit"
        class="mt-2 w-full rounded-lg bg-corporativo-blue px-6 py-3 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90"
      >
        Enviar Solicitud
      </button>
    </form>
  </main>
</StoreLayout>

<script>
  const submitButton = document.getElementById("ticket-submit");
  const form = document.getElementById("ticket-form") as HTMLFormElement | null;

  submitButton?.addEventListener("click", () => {
    if (!form?.checkValidity()) {
      form?.reportValidity();
      return;
    }
    alert("Ticket generado. Nuestro equipo de soporte te contactará a la brevedad.");
  });

  const toggleButton = document.querySelector<HTMLButtonElement>(".toggle-b2b");
  const businessFields = document.querySelector<HTMLElement>(".business-fields");

  toggleButton?.addEventListener("click", () => {
    businessFields?.classList.toggle("hidden");
    const isHidden = businessFields?.classList.contains("hidden");
    toggleButton.textContent = isHidden ? "¿Soporte para tu empresa?" : "¿Soporte personal?";
  });
</script>
