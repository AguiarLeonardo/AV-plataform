---
import Layout from "../../layouts/Layout.astro";
import PageHeader from "../../components/ui/PageHeader.astro";
import CategoryCard from "../../components/ui/CategoryCard.astro";
import { techProducts } from "../../data/techCatalog";

const categoryNames = [...new Set(techProducts.map((product) => product.category))];

const categories = categoryNames.map((categoryName) => {
  const productsInCategory = techProducts.filter((product) => product.category === categoryName);
  const subcategorySlugs = [...new Set(productsInCategory.map((product) => product.subcategorySlug))];

  const subcategories = subcategorySlugs.map((slug) => {
    const firstProduct = productsInCategory.find((product) => product.subcategorySlug === slug)!;
    return {
      slug,
      name: firstProduct.subcategoryName,
      image: firstProduct.image,
    };
  });

  return { name: categoryName, subcategories };
});
---

<Layout title="Catálogo Tecnológico - Asiaven">
  <PageHeader
    title="Catálogo Tecnológico Corporativo"
    bgImage="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&q=80&w=1920"
  />

  <div class="max-w-7xl mx-auto px-4 py-16 md:py-24">
    {
      categories.map((category) => (
        <section>
          <h2 class="text-2xl font-bold mt-12 mb-6 text-corporativo-gray first:mt-0">
            {category.name}
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {category.subcategories.map((subcategory) => (
              <CategoryCard
                href={`/tecnologia/${subcategory.slug}`}
                image={subcategory.image}
                title={subcategory.name}
              />
            ))}
          </div>
        </section>
      ))
    }
  </div>
</Layout>
