---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/sections/Navbar.astro";
import Footer from "../../../components/sections/Footer.astro";
import { techProducts } from "../../../data/techCatalog";
import { ArrowLeft, Check } from "lucide-react";

export function getStaticPaths() {
  return techProducts.map((item) => ({
    params: { producto: item.slug },
    props: { product: item },
  }));
}

const { product } = Astro.props;
---

<Layout title={`${product.title} - Catálogo Tecnológico - Asiaven`}>
  <Navbar />

  <main class="max-w-7xl mx-auto px-4 py-16">
    <a
      href={`/tecnologia/${product.subcategorySlug}`}
      class="inline-flex items-center gap-2 text-sm font-semibold text-corporativo-blue hover:underline"
    >
      <ArrowLeft className="h-4 w-4" />
      Volver al Catálogo
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-8">
      <img
        src={product.image}
        alt={product.title}
        class="w-full rounded-2xl shadow-xl object-cover"
        loading="eager"
        decoding="async"
      />

      <div>
        <span class="inline-block rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-corporativo-blue">
          {product.subcategoryName}
        </span>

        <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-corporativo-gray sm:text-4xl">
          {product.title}
        </h1>

        <p class="mt-4 text-base leading-relaxed text-gray-600">
          {product.description}
        </p>

        <hr class="my-8 border-gray-200" />

        <h2 class="text-lg font-bold text-corporativo-gray">Especificaciones Destacadas</h2>

        <ul class="mt-4 flex flex-col gap-3">
          {product.features.map((feature) => (
            <li class="flex items-start gap-3 text-gray-600">
              <Check className="mt-0.5 h-5 w-5 flex-shrink-0 text-corporativo-blue" />
              <span>{feature}</span>
            </li>
          ))}
        </ul>

        <a
          href="/contactanos"
          class="mt-10 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-corporativo-blue px-8 py-4 text-sm font-semibold text-white shadow-lg transition-colors hover:bg-corporativo-blue/90 no-underline sm:w-auto"
        >
          Solicitar Cotización &rarr;
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
